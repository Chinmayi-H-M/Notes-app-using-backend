<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quick Notes</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/stylesheet/style.css">
</head>
<body>
    <div class="main w-full min-h-screen bg-zinc-900">
        <div class="form p-10 text-white">
            <form action="/create" method="post">
                <input class='block px-5 w-full rounded-md py-2 bg-zinc-800'type="text" name="title" placeholder="Title goes here...">
                <textarea class='block mt-2  w-full rounded-md px-5 py-2 resize-none bg-zinc-800' name="details" id="" placeholder="Enter your note here..."></textarea>
                <input type="submit" class="mt-2 bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded-md" value="Add Note">
            </form>
        </div>
        <div class="tasks flex gap-4 flex-wrap p-10">
            <% if(files.length != 0){ %>
                <% files.forEach(function(file){ %>
                <div class="task min-w-72 px-3 py-2 bg-zinc-800 rounded-md m-2">
                <h3 class="text-white font-bold"><%= file %></h3>
                <div class="flex w-full item-center justify-between mt-3 ">
                <a href="/file/<%= file %>" class="text-blue-500 hover:text-blue-700">View Note</a>
                <a href="/edit/<%= file %>" class="text-zinc-600" >Edit the note</a>
                </div>
            </div>
            <% }) %>
            <% } else { %>
                <h3 class="text-white">No tasks yet</h3>
            <%  } %>
            
        </div>
    </div>
    
</body>
</html>